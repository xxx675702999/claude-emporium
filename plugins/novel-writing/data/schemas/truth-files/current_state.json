{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "current_state.json",
  "title": "CurrentState",
  "description": "Current state truth file — protagonist situation, known facts, and world state snapshot. Part of the 7 truth files per REQ-F-14.",
  "type": "object",
  "required": ["version", "chapter", "facts"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for future migration support."
    },
    "chapter": {
      "type": "integer",
      "minimum": 0,
      "description": "Chapter number this state reflects (0 for initial state)."
    },
    "facts": {
      "type": "array",
      "description": "Ordered list of facts about the current story state.",
      "items": {
        "$ref": "#/definitions/Fact"
      }
    }
  },
  "definitions": {
    "Fact": {
      "type": "object",
      "required": ["subject", "predicate", "object", "validFromChapter", "sourceChapter"],
      "additionalProperties": false,
      "properties": {
        "subject": {
          "type": "string",
          "minLength": 1,
          "description": "Entity or concept (e.g. character name, location)."
        },
        "predicate": {
          "type": "string",
          "minLength": 1,
          "description": "Relationship or attribute (e.g. 'currentLocation', 'relationship')."
        },
        "object": {
          "type": "string",
          "minLength": 1,
          "description": "Value or target (e.g. 'Azure Sect', 'allies')."
        },
        "validFromChapter": {
          "type": "integer",
          "minimum": 0,
          "description": "Chapter where this fact became true."
        },
        "validUntilChapter": {
          "type": ["integer", "null"],
          "description": "Chapter where this fact was superseded (null if still valid)."
        },
        "sourceChapter": {
          "type": "integer",
          "minimum": 0,
          "description": "Chapter that introduced this fact."
        }
      }
    }
  }
}
